generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id       String @id @default(cuid())
  email    String @unique
  password String
  name     String
}

model Profile {
  id       String @id @default("main")
  name     String @default("")
  role     String @default("")
  tagline  String @default("")
  intro    String @default("")
  summary  String @default("")
  location String @default("")
  phone    String @default("")
  email    String @default("")
  linkedin String @default("")
  photo    String @default("")
}

model Stat {
  id    String @id @default(cuid())
  value String
  label String
  order Int    @default(0)
}

model Service {
  id    String @id @default(cuid())
  name  String
  order Int    @default(0)
}

model Competency {
  id     String  @id @default(cuid())
  title  String
  accent String  @default("blue")
  order  Int     @default(0)
  skills Skill[]
}

model Skill {
  id           String     @id @default(cuid())
  name         String
  description  String     @default("")
  order        Int        @default(0)
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  competencyId String
}

model Project {
  id          String       @id @default(cuid())
  title       String
  category    String
  accent      String       @default("blue")
  description String
  link        String       @default("")
  order       Int          @default(0)
  tags        ProjectTag[]
}

model ProjectTag {
  id        String  @id @default(cuid())
  name      String
  order     Int     @default(0)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
}

model Certification {
  id     String @id @default(cuid())
  title  String
  issuer String
  code   String
  order  Int    @default(0)
}

model Experience {
  id       String             @id @default(cuid())
  title    String
  period   String
  company  String
  location String             @default("")
  order    Int                @default(0)
  bullets  ExperienceBullet[]
}

model ExperienceBullet {
  id           String     @id @default(cuid())
  text         String
  order        Int        @default(0)
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  experienceId String
}

model Education {
  id     String @id @default(cuid())
  degree String
  school String
  period String
  detail String @default("")
  order  Int    @default(0)
}

model MarqueeSkill {
  id    String @id @default(cuid())
  name  String
  order Int    @default(0)
}

model ResumeSummary {
  id   String @id @default("main")
  text String @default("")
}

model SiteContent {
  key   String @id
  value String @default("")
}
